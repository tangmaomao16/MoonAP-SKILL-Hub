    "id": "demo.utilities.bmi-calculator",
    "name": "BMI Calculator",
    "description": "Calculate body mass index from weight and height.",
    "version": "0.1.0",
    "domain": "demo",
    "subdomain": "utilities",
    "category": "demo",
    "task_kind": "generic-task",
    "runtime_mode": "form",
    "result_mode": "text",
    "folder_path": "demo/utilities/bmi-calculator",
    "zip_path": "demo/utilities/bmi-calculator.zip",
    "runtime_spec": {
      "mode": "form",
      "title": "Calculate BMI",
      "action_label": "Calculate BMI",
      "rerun_action_label": "Calculate again",
      "fields": [
        {
          "name": "weight_kg",
          "label": "Weight in kg",
          "type": "float",
          "default": 70,
          "step": 0.1
        },
        {
          "name": "height_m",
          "label": "Height in meters",
          "type": "float",
          "default": 1.75,
          "step": 0.01
        }
      ],
      "computed_outputs": [
        {
          "name": "bmi",
          "label": "BMI",
          "expression": "weight_kg / (height_m * height_m)",
          "decimals": 2
        }
      ],
      "result_template": "Weight: {{weight_kg}} kg\nHeight: {{height_m}} m\nBMI: {{bmi}}",
      "summary_template": "Calculated BMI {{bmi}}."
    }
  },
  {
    "id": "demo.utilities.circle-calculator",
    "name": "Circle Calculator",
    "description": "Calculate circle area and circumference from radius.",
    "version": "0.1.0",
    "domain": "demo",
    "subdomain": "utilities",
    "category": "demo",
    "task_kind": "generic-task",
    "runtime_mode": "form",
    "result_mode": "text",
    "folder_path": "demo/utilities/circle-calculator",
    "zip_path": "demo/utilities/circle-calculator.zip",
    "runtime_spec": {
      "mode": "form",
      "title": "Circle measurements",
      "action_label": "Calculate circle",
      "rerun_action_label": "Calculate again",
      "fields": [
        {
          "name": "radius",
          "label": "Radius",
          "type": "float",
          "default": 1,
          "step": 0.01
        }
      ],
      "computed_outputs": [
        {
          "name": "area",
          "label": "Area",
          "expression": "radius * radius * 3.141592653589793",
          "decimals": 4
        },
        {
          "name": "circumference",
          "label": "Circumference",
          "expression": "2 * 3.141592653589793 * radius",
          "decimals": 4
        }
      ],
      "result_template": "Radius: {{radius}}\nArea: {{area}}\nCircumference: {{circumference}}",
      "summary_template": "Calculated circle area {{area}} and circumference {{circumference}}."
    }
  },
  {
    "id": "demo.utilities.loan-payment-calculator",
    "name": "Loan Payment Calculator",
    "description": "Estimate monthly loan payment from principal, interest rate, and month count.",
    "version": "0.1.0",
    "domain": "demo",
    "subdomain": "utilities",
    "category": "demo",
    "task_kind": "generic-task",
    "runtime_mode": "form",
    "result_mode": "text",
    "folder_path": "demo/utilities/loan-payment-calculator",
    "zip_path": "demo/utilities/loan-payment-calculator.zip",
    "runtime_spec": {
      "mode": "form",
      "title": "Loan payment calculator",
      "action_label": "Calculate payment",
      "rerun_action_label": "Calculate again",
      "fields": [
        {
          "name": "principal",
          "label": "Principal",
          "type": "float",
          "default": 10000,
          "step": 100
        },
        {
          "name": "annual_interest_rate",
          "label": "Annual interest rate (%)",
          "type": "float",
          "default": 5,
          "step": 0.01
        },
        {
          "name": "months",
          "label": "Months",
          "type": "int",
          "default": 36,
          "min": 1,
          "step": 1
        }
      ],
      "computed_outputs": [
        {
          "name": "monthly_payment",
          "label": "Monthly payment",
          "expression": "principal * (annual_interest_rate / 100 / 12) / (1 - pow(1 + annual_interest_rate / 100 / 12, 0 - months))",
          "decimals": 2
        },
        {
          "name": "total_paid",
          "label": "Total paid",
          "expression": "monthly_payment * months",
          "decimals": 2
        },
        {
          "name": "total_interest",
          "label": "Total interest",
          "expression": "total_paid - principal",
          "decimals": 2
        }
      ],
      "result_template": "Principal: {{principal}}\nAnnual interest rate: {{annual_interest_rate}}%\nMonths: {{months}}\nMonthly payment: {{monthly_payment}}\nTotal paid: {{total_paid}}\nTotal interest: {{total_interest}}",
      "summary_template": "Monthly payment is {{monthly_payment}}."
    }
  },
  {
    "id": "demo.utilities.tip-calculator",
    "name": "Tip Calculator",
    "description": "Calculate tip, total bill, and per-person amount.",
    "version": "0.1.0",
    "domain": "demo",
    "subdomain": "utilities",
    "category": "demo",
    "task_kind": "generic-task",
    "runtime_mode": "form",
    "result_mode": "text",
    "folder_path": "demo/utilities/tip-calculator",
    "zip_path": "demo/utilities/tip-calculator.zip",
    "runtime_spec": {
      "mode": "form",
      "title": "Tip calculator",
      "action_label": "Calculate tip",
      "rerun_action_label": "Calculate again",
      "fields": [
        {
          "name": "bill_amount",
          "label": "Bill amount",
          "type": "float",
          "default": 50,
          "step": 0.01
        },
        {
          "name": "tip_percent",
          "label": "Tip percent",
          "type": "float",
          "default": 18,
          "step": 0.1
        },
        {
          "name": "people",
          "label": "Number of people",
          "type": "int",
          "default": 2,
          "min": 1,
          "step": 1
        }
      ],
      "computed_outputs": [
        {
          "name": "tip_amount",
          "label": "Tip amount",
          "expression": "bill_amount * tip_percent / 100",
          "decimals": 2
        },
        {
          "name": "total_amount",
          "label": "Total amount",
          "expression": "bill_amount + tip_amount",
          "decimals": 2
        },
        {
          "name": "per_person",
          "label": "Per person",
          "expression": "total_amount / people",
          "decimals": 2
        }
      ],
      "result_template": "Bill: {{bill_amount}}\nTip: {{tip_amount}}\nTotal: {{total_amount}}\nPer person: {{per_person}}",
      "summary_template": "Total is {{total_amount}}, or {{per_person}} per person."
    }
  },
