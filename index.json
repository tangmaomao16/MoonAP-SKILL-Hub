    "task_kind": "large-fastq-analysis",
    "runtime_mode": "file",
    "result_mode": "report",
    "folder_path": "bioinformatics/sequencing/large-fastq-analyzer",
    "zip_path": "bioinformatics/sequencing/large-fastq-analyzer.zip"
  },
